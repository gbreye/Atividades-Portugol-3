programa {
  funcao inicio() {
    real n1, n2, n3
    real media_final
    escreva("\n Digite a nota 1: ")
    leia(n1)
    escreva("\n Digite a nota 2: ")
    leia(n2)
    escreva("\n Digite a nota 3: ")
    leia(n3)
    media_final = (n1 * 2 + n2 * 3 + n3 * 5) / 10
    escreva("\n =================================================")
    escreva("\n Média final do aluno: ", media_final)
  }
}
